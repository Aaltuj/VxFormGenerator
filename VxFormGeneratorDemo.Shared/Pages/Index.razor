@page "/"

@using VxFormGenerator.Core
<h1>VxFormGenerator Demo</h1>
<br />

<div class="row">
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Model based form</h5>
                <p class="card-text">Render a form with layout information</p>
                <a href="definition-form" class="btn btn-primary">Go to demo</a>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Dynamic metadata form</h5>
                <p class="card-text">Render a dynamic form from portable runtime metadata</p>
                <a href="dynamic-form" class="btn btn-primary">Go to demo</a>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Custom field template</h5>
                <p class="card-text">Keep generated inputs and binding while owning the field HTML</p>
                <a href="custom-field-template" class="btn btn-primary">Go to demo</a>
            </div>
        </div>
    </div>
</div>
